# CareSync HIMS — Staging Environment Variables
#
# These values must be set in GitHub Actions under:
#   Settings → Environments → staging → Environment secrets
#
# The "staging" environment is used by soak-test.yml. Without a dedicated
# GitHub environment named "staging", that workflow falls back to repo-level
# secrets and may inadvertently target the production Supabase project.
#
# Current posture (2026-06-19): No dedicated staging Supabase project exists.
# The "staging" GitHub environment should point at the dev/preview Supabase
# project until a dedicated staging project is provisioned. This means:
#   - soak tests run against dev data, NOT production
#   - RLS policy changes are tested against dev schema before promotion
#   - A production-equivalent staging tier is a future infra initiative
#
# To provision a dedicated staging project:
#   1. Create a new project at supabase.com → copy URL + keys
#   2. Run `supabase db push --db-url <staging-db-url>` to apply migrations
#   3. Set the secrets below in the GitHub "staging" environment
#   4. Update staging.caresync-hims.com DNS / hosting to point to the new project

# ── Supabase ──────────────────────────────────────────────────────────────────
# Supabase project URL for staging (e.g. https://xyzstaging.supabase.co)
VITE_SUPABASE_URL=

# Supabase anon/public key for staging (safe for browser, enforced by RLS)
VITE_SUPABASE_ANON_KEY=

# Supabase service role key for staging (server-side only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
VITE_APP_ENV=staging
VITE_APP_URL=https://staging.caresync-hims.com

# ── Optional: feature flags ───────────────────────────────────────────────────
# Set to true to enable experimental features in staging before production rollout
VITE_ENABLE_FHIR_EXPORT=true
VITE_ENABLE_TELEMEDICINE=true
