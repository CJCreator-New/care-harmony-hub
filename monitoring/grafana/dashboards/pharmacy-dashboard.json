{
  "dashboard": {
    "id": null,
    "uid": "caresync-pharmacy",
    "title": "CareSync Pharmacy Workflow Dashboard",
    "description": "Pharmacist view - prescription dispensing latency, queue depth, safety blocks, stock alerts",
    "tags": ["pharmacy", "workflows", "pharmacists"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "15s",
    "panels": [
      {
        "id": 1,
        "title": "Prescription Queue Depth",
        "type": "gauge",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "caresync_pharmacy_queue_depth"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 20
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            }
          }
        },
        "options": {
          "orientation": "auto",
          "textMode": "auto",
          "showThresholdLabels": false,
          "showThresholdMarkers": true,
          "gaugeSize": "auto"
        }
      },
      {
        "id": 2,
        "title": "Dispensing Latency (p95)",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "(histogram_quantile(0.95, rate(caresync_prescription_dispensing_latency_ms_bucket[5m])) / 1000 / 60)",
            "legendFormat": "Minutes"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 12
                },
                {
                  "color": "red",
                  "value": 15
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Dispensing Rate (per minute)",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "rate(caresync_prescriptions_dispensed_total[5m]) * 60",
            "legendFormat": "Rx/min"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Blocked Prescriptions (24h)",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 6
        },
        "targets": [
          {
            "expr": "increase(caresync_prescription_dispensing_blocked_total[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null,
                  "value": 5
                },
                {
                  "color": "yellow",
                  "value": 5
                },
                {
                  "color": "red",
                  "value": 10
                }
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Queue Depth Trend",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 6,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "caresync_pharmacy_queue_depth",
            "legendFormat": "Queue Depth",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        },
        "options": {
          "legend": {
            "calcs": ["mean", "max", "last"],
            "displayMode": "table"
          }
        }
      },
      {
        "id": 6,
        "title": "Dispensing Latency Histogram",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 6,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(caresync_prescription_dispensing_latency_ms_bucket[5m])) / 1000 / 60",
            "legendFormat": "p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(caresync_prescription_dispensing_latency_ms_bucket[5m])) / 1000 / 60",
            "legendFormat": "p50",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "custom": {
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 12
                },
                {
                  "color": "red",
                  "value": 15
                }
              ]
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Block Reasons (24h)",
        "type": "piechart",
        "gridPos": {
          "x": 0,
          "y": 12,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "sum by (block_reason) (increase(caresync_prescription_dispensing_blocked_total[24h]))",
            "format": "heatmap"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            }
          }
        },
        "options": {
          "reduceOptions": {
            "values": false,
            "fields": "",
            "calcs": ["lastNotNull"]
          },
          "pieType": "pie",
          "displayLabels": ["name", "value"],
          "legend": {
            "values": []
          }
        }
      },
      {
        "id": 8,
        "title": "Stock Alerts (Critical)",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 12,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "count(caresync_medication_stock_level < caresync_medication_reorder_threshold)"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1
                },
                {
                  "color": "red",
                  "value": 5
                }
              ]
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
