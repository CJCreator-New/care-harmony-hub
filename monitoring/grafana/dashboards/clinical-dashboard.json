{
  "dashboard": {
    "id": null,
    "uid": "caresync-clinical",
    "title": "CareSync Clinical Workflow Dashboard",
    "description": "Real-time clinical workflow metrics for doctors - prescription latency, lab results, patient search SLOs",
    "tags": ["clinical", "workflows", "doctors"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Prescription Creation Latency (p95)",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(caresync_prescription_creation_latency_ms_bucket[5m])) / 1000",
            "legendFormat": "Seconds"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 240
                },
                {
                  "color": "red",
                  "value": 300
                }
              ]
            }
          }
        },
        "options": {
          "graphMode": "area",
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background"
        }
      },
      {
        "id": 2,
        "title": "Lab Critical Value Alert Latency (p99)",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(caresync_lab_critical_value_latency_ms_bucket[5m])) / 1000"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 240
                },
                {
                  "color": "red",
                  "value": 300
                }
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Patient Search Latency (p95)",
        "type": "stat",
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(caresync_patient_search_latency_ms_bucket[5m]))"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1500
                },
                {
                  "color": "red",
                  "value": 2000
                }
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Active Prescriptions (Last 24h)",
        "type": "stat",
        "gridPos": {
          "x": 18,
          "y": 0,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "increase(caresync_prescriptions_created_total[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Prescription Latency Trend",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 4,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(caresync_prescription_creation_latency_ms_bucket[5m])) / 1000",
            "legendFormat": "p95 (seconds)",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(caresync_prescription_creation_latency_ms_bucket[5m])) / 1000",
            "legendFormat": "p50 (seconds)",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "lineWidth": 2
            }
          }
        },
        "options": {
          "legend": {
            "calcs": ["mean", "last"],
            "displayMode": "table"
          }
        }
      },
      {
        "id": 6,
        "title": "Lab Critical Values (24h)",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 4,
          "w": 12,
          "h": 6
        },
        "targets": [
          {
            "expr": "increase(caresync_lab_critical_values_detected_total[24h])",
            "legendFormat": "Total Critical Values",
            "refId": "A"
          },
          {
            "expr": "increase(caresync_lab_critical_value_alerts_sent_total[24h])",
            "legendFormat": "Alerts Sent",
            "refId": "B"
          },
          {
            "expr": "increase(caresync_lab_critical_value_alerts_acknowledged_total[24h])",
            "legendFormat": "Acknowledged",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "lineWidth": 2
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Medication Interaction Detections",
        "type": "timeseries",
        "gridPos": {
          "x": 0,
          "y": 10,
          "w": 12,
          "h": 5
        },
        "targets": [
          {
            "expr": "rate(caresync_medication_interaction_detected_total[5m])",
            "legendFormat": "Interactions/sec"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "1/s",
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 20
            }
          }
        },
        "alert": {
          "name": "Any Medication Interaction",
          "conditions": [
            {
              "evaluator": {
                "params": [0],
                "type": "gt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "last"
              },
              "type": "query"
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Patient Search Performance",
        "type": "timeseries",
        "gridPos": {
          "x": 12,
          "y": 10,
          "w": 12,
          "h": 5
        },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, rate(caresync_patient_search_latency_ms_bucket[5m]))",
            "legendFormat": "p95",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.50, rate(caresync_patient_search_latency_ms_bucket[5m]))",
            "legendFormat": "p50",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "custom": {
              "lineWidth": 2
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 1500
                },
                {
                  "color": "red",
                  "value": 2000
                }
              ]
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Consultation Wait Times (p95)",
        "type": "stat",
        "gridPos": {
          "x": 0,
          "y": 15,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "(histogram_quantile(0.95, rate(caresync_consultation_wait_latency_ms_bucket[5m])) / 1000 / 60)",
            "legendFormat": "Minutes"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 25
                },
                {
                  "color": "red",
                  "value": 30
                }
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Prescriptions Blocked (Safety)",
        "type": "stat",
        "gridPos": {
          "x": 6,
          "y": 15,
          "w": 6,
          "h": 4
        },
        "targets": [
          {
            "expr": "increase(caresync_prescription_dispensing_blocked_total[24h])"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "custom": {
              "hideFrom": {
                "legend": false,
                "tooltip": false,
                "viz": false
              }
            },
            "color": {
              "mode": "fixed"
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}
