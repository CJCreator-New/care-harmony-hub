{
  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:dev": "vite build --mode development",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "migrate:rls": "node scripts/apply-rls-migration.mjs",
    "test:security": "vitest run tests/security",
    "test:accessibility": "vitest run tests/accessibility",
    "test:integration": "vitest run --config vitest.integration.config.ts tests/integration",
    "test:api": "vitest run tests/api",
    "test:performance": "vitest run --config vitest.performance.config.ts tests/performance",
    "test:performance:backend": "vitest run --config vitest.performance.config.ts tests/performance/backend-performance.test.ts",
    "test:performance:frontend": "vitest run --config vitest.performance.config.ts tests/performance/frontend-performance.test.ts",
    "test:performance:infrastructure": "vitest run --config vitest.performance.config.ts tests/performance/infrastructure-performance.test.ts",
    "test:performance:coverage": "vitest run --config vitest.performance.config.ts --coverage tests/performance",
    "test:load": "k6 run tests/performance/load-test.js",
    "test:load:staging": "k6 run --env BASE_URL=https://staging.caresync.local tests/performance/load-test.js",
    "test:all": "vitest run && npm run test:e2e",
    "test:start": "node scripts/start-automated-tests.mjs",
