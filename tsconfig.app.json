{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/integrations/supabase/client": [
        "./src/integrations/supabase/query-helper.ts"
      ]
    },
    "skipLibCheck": true,
    "strict": false,
    "strictNullChecks": false,
    "strictFunctionTypes": false,
    "strictPropertyInitialization": false,
    "target": "ES2020",
    "types": ["vite/client"],
    "useDefineForClassFields": true
  },
  "include": [
    "src"
  ],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**",
    "src/test/**",
    "src/__tests__/**",
    "src/components/features/appointments/**",
    "src/components/features/appointment-recurrence/**",
    "src/components/features/telehealth/**",
    "src/components/features/clinical-notes/**",
    "src/components/features/billing/BillingDashboard.tsx",
    "src/components/features/billing/BillingInvoiceGenerator.tsx",
    "src/components/features/billing/InsuranceClaimUI.tsx",
    "src/components/patients/PatientRegistrationModal.STANDARDIZED.tsx",
    "src/components/doctor/EnhancedPrescriptionForm.tsx",
    "src/components/laboratory/EnhancedLabOrderForm.tsx",
    "src/hooks/useBreakGlassOverride.ts",
    "src/hooks/useConsolidatedSubscription.ts"
  ]
}